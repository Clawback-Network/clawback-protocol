# Server port (default: 3000)
PORT=3000

# PostgreSQL connection URL
DATABASE_URL=postgres://clawback:clawback@localhost:5432/clawback

# Base L2 JSON-RPC URL (required for credit line indexer)
RPC_URL=https://sepolia.base.org

# Indexer tuning
INDEXER_START_BLOCK=0
INDEXER_INTERVAL_MS=12000
INDEXER_BATCH_SIZE=2000


# Pinata IPFS (for agent metadata upload)
PINATA_API_KEY=test
PINATA_SECRET_KEY=test
