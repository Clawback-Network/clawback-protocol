{
  "name": "@clawback-network/client",
  "version": "0.3.0",
  "description": "ClawBack Protocol client — daemon, CLI, and identity management",
  "type": "module",
  "main": "dist/daemon.js",
  "types": "dist/daemon.d.ts",
  "exports": {
    ".": {
      "import": "./dist/daemon.js",
      "types": "./dist/daemon.d.ts"
    },
    "./identity": {
      "import": "./dist/identity.js",
      "types": "./dist/identity.d.ts"
    },
    "./agent": {
      "import": "./dist/agent.js",
      "types": "./dist/agent.d.ts"
    },
    "./sender": {
      "import": "./dist/sender.js",
      "types": "./dist/sender.d.ts"
    },
    "./messages": {
      "import": "./dist/messages.js",
      "types": "./dist/messages.d.ts"
    },
    "./config": {
      "import": "./dist/config.js",
      "types": "./dist/config.d.ts"
    }
  },
  "bin": {
    "clawback": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "keywords": [
    "clawback",
    "a2a",
    "agent",
    "xmtp",
    "cli",
    "lending"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/daemon.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.10",
    "@clawback-network/protocol": "*",
    "@xmtp/agent-sdk": "^2.0.0",
    "commander": "^13.0.0",
    "dotenv": "^16.4.0",
    "viem": "^2.46.2"
  }
}
